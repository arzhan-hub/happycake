# Hackathon MCP — Steppe Business Club team token
SBC_TOKEN=sbc_team_REPLACE_WITH_YOURS

# Public URL where the MCP forwards inbound webhooks
# (set after `cloudflared tunnel --url http://localhost:8080`; URL rotates per restart)
PUBLIC_WEBHOOK_BASE_URL=https://your-subdomain.trycloudflare.com

# Telegram bots (one for all)
TELEGRAM_SALES_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# Path to claude binary (default: `claude` on PATH)
CLAUDE_BIN=claude

# Storefront origin(s) allowed by CORS for /api/* (comma-separated, * for any)
WEBSITE_CORS_ORIGINS=http://localhost:3000
