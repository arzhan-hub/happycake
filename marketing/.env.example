# Sandbox MCP credentials for the Steppe Business Club hackathon environment.
# Copy to .env and fill in your team token, or export in your shell before
# running marketing/run-loop.mjs.

# Team token issued by Steppe Business Club. NEVER commit a real token.
SBC_TEAM_TOKEN=sbc_team_your_token_here

# MCP endpoint. Override only if SBC moves the endpoint.
SBC_MCP_ENDPOINT=https://www.steppebusinessclub.com/api/mcp
